---
import { Icon } from 'lucide-react';
---

<header>
  <!-- Top Info Bar - desktop only -->
  <div class="bg-ccr-navy text-white py-2 px-4 sm:px-8 text-sm hidden sm:block">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <div class="flex gap-6">
        <div class="flex items-center gap-2">
          <span>📞 913-208-3171</span>
        </div>
        <div class="flex items-center gap-2">
          <span>📍 Gardner, KS 66030</span>
        </div>
      </div>
      <div class="text-xs text-gray-300">Mon-Fri: 8am-5pm | Sat: 9am-1pm | Sun: Closed</div>
    </div>
  </div>

  <!-- Main Navigation -->
  <nav class="sticky top-0 z-50 bg-white border-b border-ccr-light shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 py-3 sm:py-4">
      <div class="flex justify-between items-center">
        <!-- Logo & Company Name -->
        <a href="/" class="flex items-center gap-2 sm:gap-3 hover:opacity-80 transition">
          <img src="/images/logo.jpg" alt="CCR Logo" class="h-10 w-10 sm:h-12 sm:w-12" />
          <div>
            <div class="text-base sm:text-lg font-bold text-ccr-navy leading-tight">CORSON</div>
            <div class="text-[10px] sm:text-xs text-ccr-gray leading-tight">Construction</div>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-8">
          <a
            href="/"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Home
          </a>
          <a
            href="/services"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/services'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Services
          </a>
          <a
            href="/gallery"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/gallery'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Gallery
          </a>
          <a
            href="/contact"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/contact'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Contact
          </a>
        </div>

        <!-- CTA Button (desktop) -->
        <a
          href="/contact"
          class="hidden lg:block px-6 py-2 bg-ccr-blue text-white font-semibold hover:bg-ccr-navy transition"
          style={{ borderRadius: '2px' }}
        >
          Free Quote
        </a>

        <!-- Mobile Menu Toggle — 44px minimum touch target -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex items-center justify-center w-11 h-11 text-ccr-navy hover:text-ccr-blue transition -mr-2"
          aria-label="Toggle menu"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Navigation Menu -->
      <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-ccr-light pt-4">
        <a href="/" class="block py-3 text-ccr-gray hover:text-ccr-blue font-medium text-base">Home</a>
        <a href="/services" class="block py-3 text-ccr-gray hover:text-ccr-blue font-medium text-base">Services</a>
        <a href="/gallery" class="block py-3 text-ccr-gray hover:text-ccr-blue font-medium text-base">Gallery</a>
        <a href="/contact" class="block py-3 text-ccr-gray hover:text-ccr-blue font-medium text-base">Contact</a>
        <!-- Mobile phone link -->
        <a href="tel:9132083171" class="block py-3 text-ccr-blue font-medium text-base">📞 913-208-3171</a>
        <a
          href="/contact"
          class="block mt-2 px-4 py-3 bg-ccr-blue text-white font-semibold text-center hover:bg-ccr-navy transition text-base"
          style={{ borderRadius: '2px' }}
        >
          Free Quote
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (menuBtn && menu && iconOpen && iconClose) {
    menuBtn.addEventListener('click', () => {
      const isHidden = menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden', !isHidden);
      iconClose.classList.toggle('hidden', isHidden);
    });

    // Close menu when a link is clicked
    const menuLinks = menu.querySelectorAll('a');
    menuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      });
    });
  }
</script>
