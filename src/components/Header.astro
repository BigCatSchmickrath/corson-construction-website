---
import { Icon } from 'lucide-react';
---

<header>
  <!-- Top Info Bar -->
  <div class="bg-ccr-navy text-white py-2 px-4 sm:px-8 text-sm hidden sm:block">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <div class="flex gap-6">
        <div class="flex items-center gap-2">
          <span>📞 913-208-3171</span>
        </div>
        <div class="flex items-center gap-2">
          <span>📍 Gardner, KS 66030</span>
        </div>
      </div>
      <div class="text-xs text-gray-300">Mon-Fri: 8am-5pm | Sat: 9am-1pm | Sun: Closed</div>
    </div>
  </div>

  <!-- Main Navigation -->
  <nav class="sticky top-0 z-50 bg-white border-b border-ccr-light shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 py-4">
      <div class="flex justify-between items-center">
        <!-- Logo & Company Name -->
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
          <img src="/logo.svg" alt="CCR Logo" class="h-12 w-12" />
          <div class="hidden sm:block">
            <div class="text-lg font-bold text-ccr-navy">CORSON</div>
            <div class="text-xs text-ccr-gray">Construction & Roofing</div>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-8">
          <a
            href="/"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Home
          </a>
          <a
            href="/services"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/services'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Services
          </a>
          <a
            href="/gallery"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/gallery'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Gallery
          </a>
          <a
            href="/contact"
            class={`font-medium transition py-2 px-1 border-b-2 ${
              Astro.url.pathname === '/contact'
                ? 'text-ccr-blue border-ccr-blue'
                : 'text-ccr-gray border-transparent hover:text-ccr-blue'
            }`}
          >
            Contact
          </a>
        </div>

        <!-- CTA Button -->
        <a
          href="/contact"
          class="hidden lg:block px-6 py-2 bg-ccr-blue text-white font-semibold hover:bg-ccr-navy transition"
          style={{ borderRadius: '2px' }}
        >
          Free Quote
        </a>

        <!-- Mobile Menu Toggle -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden text-ccr-navy hover:text-ccr-blue transition"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Navigation Menu -->
      <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-ccr-light pt-4">
        <a href="/" class="block py-2 text-ccr-gray hover:text-ccr-blue font-medium">Home</a>
        <a href="/services" class="block py-2 text-ccr-gray hover:text-ccr-blue font-medium">Services</a>
        <a href="/gallery" class="block py-2 text-ccr-gray hover:text-ccr-blue font-medium">Gallery</a>
        <a href="/contact" class="block py-2 text-ccr-gray hover:text-ccr-blue font-medium">Contact</a>
        <a
          href="/contact"
          class="block mt-4 px-4 py-2 bg-ccr-blue text-white font-semibold text-center hover:bg-ccr-navy transition"
          style={{ borderRadius: '2px' }}
        >
          Free Quote
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (menuBtn && menu) {
    menuBtn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    const menuLinks = menu.querySelectorAll('a');
    menuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
