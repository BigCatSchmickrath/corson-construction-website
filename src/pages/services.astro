---
import Layout from '@/layouts/Layout.astro';
import { services } from '@/data/services';
---

<Layout title="Services | Corson Construction & Roofing">
  <!-- Page Hero Banner -->
  <section class="bg-ccr-navy text-white py-12 px-4 sm:px-8">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">Our Services</h1>
      <div class="flex items-center gap-2 text-sm">
        <a href="/" class="hover:text-ccr-gold transition">Home</a>
        <span class="text-ccr-gold">/</span>
        <span class="text-ccr-light">Services</span>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 sm:py-24 px-4 sm:px-8 bg-white">
    <div class="max-w-6xl mx-auto mb-12">
      <p class="text-center text-lg text-ccr-gray max-w-3xl mx-auto mb-12">
        From roofing to remodeling, we offer comprehensive construction services tailored to your home's needs. With 20+ years of experience, quality is guaranteed on every project.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          services.map((service) => (
            <div
              class="bg-white border border-ccr-light rounded-sharp p-8 hover:shadow-lg transition group cursor-pointer"
              style={{
                borderBottom: '3px solid transparent',
              }}
              onmouseenter="this.style.borderBottomColor = '#2c5f8a'"
              onmouseleave="this.style.borderBottomColor = 'transparent'"
            >
              <div class="w-12 h-12 bg-ccr-light rounded-sharp flex items-center justify-center mb-6 group-hover:bg-ccr-blue group-hover:text-white transition text-2xl">
                {service.icon === 'Hammer' && '🔨'}
                {service.icon === 'Utensils' && '🍽️'}
                {service.icon === 'Droplets' && '💧'}
                {service.icon === 'Home' && '🏠'}
                {service.icon === 'Building2' && '🏢'}
                {service.icon === 'Layers' && '📦'}
              </div>

              <h3 class="text-2xl font-bold text-ccr-navy mb-3">{service.title}</h3>
              <p class="text-ccr-gray mb-6 leading-relaxed">{service.description}</p>

              <div class="space-y-2">
                {service.features.map((feature) => (
                  <div class="flex items-start gap-2">
                    <span class="text-ccr-gold font-bold mt-1">✓</span>
                    <span class="text-sm text-ccr-gray">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20 px-4 sm:px-8 bg-ccr-light">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-ccr-navy mb-6">Ready to Start Your Project?</h2>
      <p class="text-lg text-ccr-gray mb-8 max-w-2xl mx-auto">
        Contact us today for a free consultation and estimate. Our team is ready to bring your vision to life.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-3 bg-ccr-blue text-white font-bold hover:bg-ccr-navy transition text-lg"
        style={{ borderRadius: '2px' }}
      >
        Get Your Free Estimate
      </a>
    </div>
  </section>
</Layout>
