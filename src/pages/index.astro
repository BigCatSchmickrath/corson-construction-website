---
import Layout from '@/layouts/Layout.astro';
import { projects } from '@/data/projects';

const featuredProjects = projects.slice(0, 4);
const reviews = [
  {
    name: 'John Smith',
    rating: 5,
    text: 'Excellent work on our basement remodel. The team was professional and finished on schedule.',
  },
  {
    name: 'Sarah Johnson',
    rating: 5,
    text: 'Our new deck looks amazing! Highly recommend Corson Construction for any project.',
  },
  {
    name: 'Mike Davis',
    rating: 5,
    text: 'Top-notch work on our pavilion and patio. They delivered exactly what we envisioned.',
  },
];

const serviceAreas = [
  'Gardner',
  'Edgerton',
  'Spring Hill',
  'Stilwell',
  'Olathe',
  'De Soto',
];
---

<Layout title="Corson Construction | Custom Home Improvements & Outdoor Living in Kansas">
  <!-- Hero Section -->
  <section class="relative py-16 sm:py-28 px-4 sm:px-8 overflow-hidden">
    <img src="/images/hero-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-ccr-navy/70"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <!-- Logo with Glow Effect -->
      <div class="mb-6 sm:mb-8 flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-white opacity-20 blur-xl rounded-full" style="width: 100%; height: 100%; left: 50%; top: 50%; transform: translate(-50%, -50%)"></div>
          <img src="/images/logo.jpg" alt="CCR Logo" class="h-24 w-24 sm:h-32 sm:w-32 relative z-10 mx-auto" />
        </div>
      </div>

      <!-- Tracked Out Headline -->
      <h1 class="text-3xl sm:text-6xl font-black text-white mb-2 tracking-wider sm:tracking-widest">
        CORSON CONSTRUCTION
      </h1>

      <!-- Gold Separator -->
      <div class="flex justify-center gap-2 mb-4 sm:mb-6">
        <div class="w-2 h-2 bg-ccr-gold rounded-sharp"></div>
        <div class="w-2 h-2 bg-ccr-gold rounded-sharp"></div>
        <div class="w-2 h-2 bg-ccr-gold rounded-sharp"></div>
      </div>

      <!-- Main Tagline -->
      <h2 class="text-xl sm:text-3xl font-bold text-white mb-4 sm:mb-6">Quality Construction You Can Count On</h2>

      <!-- Description -->
      <p class="text-base sm:text-lg text-gray-200 mb-6 sm:mb-8 max-w-2xl mx-auto">
        With over 20 years of family-owned expertise, we specialize in custom basements, outdoor living spaces, and home improvements throughout Johnson County, Kansas. Licensed, insured, and committed to excellence.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center mb-8 sm:mb-12">
        <a
          href="/contact"
          class="px-6 sm:px-8 py-3 bg-ccr-gold text-ccr-navy font-bold hover:bg-white transition text-base sm:text-lg"
          style={{ borderRadius: '2px' }}
        >
          Get Free Estimate
        </a>
        <a
          href="tel:9132083171"
          class="px-6 sm:px-8 py-3 border-2 border-white text-white font-bold hover:bg-white hover:text-ccr-navy transition text-base sm:text-lg"
          style={{ borderRadius: '2px' }}
        >
          Call: 913-208-3171
        </a>
      </div>

      <!-- Trust Badges -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-white/10 backdrop-blur-sm p-3 sm:p-4 rounded-sharp border border-white/20">
          <div class="text-sm font-semibold text-ccr-gold mb-1">✓</div>
          <div class="text-xs font-bold text-white">Licensed & Insured</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-3 sm:p-4 rounded-sharp border border-white/20">
          <div class="text-sm font-semibold text-ccr-gold mb-1">★</div>
          <div class="text-xs font-bold text-white">Family Owned</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-3 sm:p-4 rounded-sharp border border-white/20">
          <div class="text-sm font-semibold text-ccr-gold mb-1">4.4</div>
          <div class="text-xs font-bold text-white">Google Rating</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm p-3 sm:p-4 rounded-sharp border border-white/20">
          <div class="text-sm font-semibold text-ccr-gold mb-1">20+</div>
          <div class="text-xs font-bold text-white">Years Experience</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview Section -->
  <section class="py-12 sm:py-24 px-4 sm:px-8 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-8 sm:mb-12">
        <h2 class="text-2xl sm:text-4xl font-bold text-ccr-navy mb-3 sm:mb-4">Our Work</h2>
        <p class="text-base sm:text-lg text-ccr-gray max-w-2xl mx-auto">
          From custom basements to outdoor living spaces, we take pride in every project. See why homeowners in Johnson County trust Corson Construction.
        </p>
      </div>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 mb-8 sm:mb-12">
        {
          featuredProjects.map((project) => (
            <a
              href="/gallery"
              class="group relative overflow-hidden rounded-sharp border border-ccr-light hover:border-ccr-blue transition"
            >
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-48 sm:h-64 object-cover group-hover:scale-105 transition duration-300"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent opacity-60 sm:opacity-0 sm:group-hover:opacity-60 transition duration-300"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4 sm:transform sm:translate-y-4 sm:group-hover:translate-y-0 transition duration-300">
                <div class="text-ccr-gold text-sm font-semibold">{project.category}</div>
                <h3 class="text-white font-bold text-base sm:text-lg">{project.title}</h3>
              </div>
            </a>
          ))
        }
      </div>

      <!-- View All Button -->
      <div class="text-center">
        <a
          href="/gallery"
          class="inline-block px-6 sm:px-8 py-3 bg-ccr-light text-ccr-blue font-bold hover:bg-ccr-blue hover:text-white transition text-base sm:text-lg"
          style={{ borderRadius: '2px' }}
        >
          View All Projects →
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="py-12 sm:py-24 px-4 sm:px-8 bg-ccr-light">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-8 sm:mb-12">
        <h2 class="text-2xl sm:text-4xl font-bold text-ccr-navy mb-3 sm:mb-4">What Our Customers Say</h2>
        <div class="flex items-center justify-center gap-2 mb-4">
          <div class="flex gap-1">
            {[1, 2, 3, 4, 5].map(() => (
              <span class="text-ccr-gold text-xl">★</span>
            ))}
          </div>
          <span class="text-base sm:text-lg font-bold text-ccr-navy">4.4 Google Rating</span>
        </div>
      </div>

      <!-- Review Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-8">
        {
          reviews.map((review) => (
            <div class="bg-white p-4 sm:p-6 rounded-sharp border border-ccr-light hover:shadow-md transition">
              <div class="flex gap-1 mb-3 sm:mb-4">
                {[...Array(review.rating)].map(() => (
                  <span class="text-ccr-gold text-lg">★</span>
                ))}
              </div>
              <p class="text-ccr-gray mb-3 sm:mb-4 leading-relaxed text-sm sm:text-base">"{review.text}"</p>
              <p class="font-bold text-ccr-navy text-sm sm:text-base">{review.name}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service Area Banner -->
  <section class="py-12 sm:py-20 px-4 sm:px-8 bg-ccr-navy text-white">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-2xl sm:text-4xl font-bold mb-6 sm:mb-8">Serving Johnson County</h2>
      <div class="flex flex-wrap justify-center items-center gap-2 sm:gap-3 text-base sm:text-lg font-medium">
        {serviceAreas.map((area, index) => (
          <>
            <span>{area}</span>
            {index < serviceAreas.length - 1 && <span class="text-ccr-gold text-xl sm:text-2xl">•</span>}
          </>
        ))}
      </div>
    </div>
  </section>
</Layout>
